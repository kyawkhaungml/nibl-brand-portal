# Copy to .env.local and fill in.

# --- Supabase (same project as the main NiBL apps) --------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — used by API routes if/when they need elevated reads.
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (server-only — NEVER expose with NEXT_PUBLIC_) ---------------
ANTHROPIC_API_KEY=

# --- App behavior -----------------------------------------------------------
# When 'true', all data is read from src/lib/mock-data.ts (Kace Beverages demo).
# Flip to 'false' once real Supabase wiring lands.
NEXT_PUBLIC_USE_MOCK_DATA=true

# Canonical site URL (used in metadata only).
NEXT_PUBLIC_SITE_URL=https://brand.nibl.food
